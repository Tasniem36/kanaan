# Copy to .env on the server and fill in. Used by docker-compose.prod.yml.

# Your domain (no https://, no trailing slash). Caddy gets HTTPS for it automatically.
DOMAIN=dukkan-kanaan.com

# Database
DB_NAME=dukkan
DB_PASSWORD=use-a-long-random-password-here

# Auth — MUST be a long random string in production
JWT_SECRET=paste-a-64-char-random-string-here

# First manager account, created automatically on first boot
SEED_MANAGER_EMAIL=you@example.com
SEED_MANAGER_PASSWORD=a-strong-password

# Optional: WhatsApp new-order alerts via CallMeBot (see DEPLOY.md "WhatsApp alerts").
# Your number in international form, e.g. 9715XXXXXXXX (no + or spaces).
WHATSAPP_PHONE=
WHATSAPP_APIKEY=
