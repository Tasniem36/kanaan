# Copy to server/.env and fill in.

# --- Database (Cloud SQL for PostgreSQL) ---
# Local dev via Cloud SQL Auth Proxy (recommended): run the proxy, then:
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=dukkan
# DB_SSL=true   # only if connecting directly over public IP without the proxy

# On Cloud Run instead, leave DB_HOST unset and set:
# INSTANCE_CONNECTION_NAME=your-project:region:instance

# --- Auth ---
JWT_SECRET=generate-a-long-random-string

# --- Server ---
PORT=8080
# Comma-separated list of allowed frontend origins (dev + prod):
CORS_ORIGIN=http://localhost:5173
