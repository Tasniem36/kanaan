# Caddy auto-provisions a free Let's Encrypt HTTPS certificate and reverse-proxies
# to the web (nginx) container. Domain is written in directly (Caddy does not read
# .env, so a {$DOMAIN} placeholder would be empty and fail to parse).
dukkan-kanaan.com {
	reverse_proxy web:80
}

# send www.dukkan-kanaan.com → dukkan-kanaan.com
www.dukkan-kanaan.com {
	redir https://dukkan-kanaan.com{uri} permanent
}
